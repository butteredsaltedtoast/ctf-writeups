---
import BaseLayout from '../layouts/BaseLayout.astro';

import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

import ShootingStars from '../components/ShootingStars.astro';

const recentWriteups = (await getCollection('writeups'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);

---

<BaseLayout title=".butteredtoast" description="Writeups from CTFs I've participated in." showStars={true}>

	<ShootingStars />

	<style>

		main {
			display: flex;
			flex-direction: column;
			padding: 6em 2em;
			gap: 4em;
		}	

		.hero {
			display: flex;
			flex-direction: column;
		}

		.handle {
			font-family: 'Space Grotesk', sans-serif;
			font-size: clamp(2.5rem, 6vw, 5rem);
			margin: 0;
		}

		.recent {
			max-width: 800px;
			width: 100%;
		}

	</style>

	<section class="hero">
		<h1 class = "handle">.butteredtoast</h1>
	</section>

	<hr />

	<section class="recent">
		<h2>Recent Writeups</h2>

		<div class="recent-grid">
			{recentWriteups.map((post) => (
				<a href={`/writeups/${post.id}/`} class="card">
					<div class="card-top">
						<span class="category">{post.data.category}</span>
						<span class="ctf">{post.data.ctf}</span>
					</div>
					<h3 class="title">{post.data.title}</h3>
					<div class="card-bottom">
						<span class="date"><FormattedDate date={post.data.pubDate} /></span>
					</div>
				</a>
			))}
		</div>

	</section>
</BaseLayout>