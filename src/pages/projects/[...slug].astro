---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Stars from '../../components/Stars.astro';

import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('projects');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'projects'>;

// @ts-ignore
const post = Astro.props;
const { Content } = await render(post);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`${post.data.title} | ${SITE_TITLE}`} description={post.data.description} />
    </head>
    <body>
        <Stars />
        <Header />
        <main>
            <h1>{post.data.title}</h1>
            <p>{post.data.stack?.join(', ')}</p>
            <a href={post.data.github} target="_blank" rel="noopener noreferrer">View GitHub Repository</a>
        <Content />
        </main>
        <Footer />
    </body>
</html>
